{
	"$schema": "https://json-schema.org/draft-07/schema#",
	"type": "object",
	"properties": {
		"format_version": {
			"type": "integer",
			"const": 3
		},
		"format_uuid": {
			"type": "string",
			"const": "289f771f-2c9a-4d73-9f3f-8492495a924d"
		},
		"packages": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"tooth": {
						"type": "string",
						"pattern": "^(?:[a-z0-9](?:[a-z0-9-]*[a-z0-9])?\\.)*[a-z0-9][a-z0-9-]*[a-z0-9](?:/[a-z0-9]+(?:[._-][a-z0-9]+)*)*$"
					},
					"info": {
						"type": "object",
						"properties": {
							"name": {
								"type": "string"
							},
							"description": {
								"type": "string"
							},
							"tags": {
								"type": "array",
								"items": {
									"type": "string",
									"pattern": "^[a-z0-9-]+(:[a-z0-9-]+)?$"
								}
							},
							"avatar_url": {
								"type": "string"
							}
						},
						"required": [
							"name",
							"description",
							"tags",
							"avatar_url"
						 ]
					},
					"stars": {
						"type": "integer"
					},
					"updated": {
						"type": "string",
						"format": "date-time"
					},
					"versions": {
						"type": "array",
						"items": {
							"type": "string",
							"pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$"
						}
					}
				},
				"required": [
					"info",
					"stars",
					"updated",
					"versions"
				]
			}
		}
	},
	"required": [
		"format_version",
		"format_uuid",
		"packages"
	]
}